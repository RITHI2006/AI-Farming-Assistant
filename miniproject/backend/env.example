# ==================== AUTHENTICATION ====================
# Database URL - SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite:///./farmers.db
# For PostgreSQL: DATABASE_URL=postgresql://user:password@localhost/farming_db

# JWT Secret Key - Change this to a secure random string in production
SECRET_KEY=your-super-secret-key-change-in-production-123456

# Token Expiration (in minutes) - Default: 43200 (30 days)
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# ==================== TWILIO CONFIGURATION ====================
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# ==================== AI API KEYS ====================
# Use at least one of the following
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ==================== BHASHINI API ====================
# Optional - for Tamil voice transcription
BHASHINI_API_KEY=your_bhashini_api_key_here

# ==================== MONGODB (OPTIONAL) ====================
MONGODB_URL=mongodb://localhost:27017

# ==================== SERVER CONFIGURATION ====================
PORT=8000
HOST=0.0.0.0
DEBUG=false






